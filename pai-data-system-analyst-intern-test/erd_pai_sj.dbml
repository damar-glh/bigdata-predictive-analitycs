Table surat_jalan {
  SJ_id varchar(10) [pk]
  Status varchar(20) [note: "Draft, Actual, Cancel, Replacement"]
  Date date
  From varchar(10) [ref: > warehouse.From]
  Created_By varchar(50)
  Remarks text
}

Table warehouse {
  From varchar(10)
  Port_Code varchar(10)

  indexes {
    (From, Port_Code) [pk]
  }
}

Table destination {
  SJ_id varchar(10) [ref: > surat_jalan.SJ_id]
  Dest varchar(20)

  indexes {
    (SJ_id, Dest) [pk]
  }
}

Table product {
  SJ_id varchar(10) [ref: > surat_jalan.SJ_id]
  Product varchar(50)
  Qty decimal(10,2)
  UOM varchar(5)

  indexes {
    (SJ_id, Product) [pk]
  }
}

Table split {
  SJ_id varchar(10) [pk, ref: > surat_jalan.SJ_id]
  SJ_ref varchar(10) [ref: > surat_jalan.SJ_id, note: "Merujuk pada SJ untuk Replacement/Split"]
  Split_Group_ID varchar(10)
}